        "    model = models.resnet18(pretrained=True)\n",
        "    model.conv1 = nn.Conv2d(1,64,kernel_size=7,stride=2,padding=3,bias=False)\n",
        "    model.fc = nn.Linear(model.fc.in_features, 10)\n",
