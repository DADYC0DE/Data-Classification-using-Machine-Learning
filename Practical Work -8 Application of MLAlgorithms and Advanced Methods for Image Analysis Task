    {
      "cell_type": "code",
      "source": [
        "class FashionDataset(Dataset):\n",
        "    def __init__(self, df):\n",
        "        self.X = df.iloc[:, 1:].values.astype(np.float32) / 255.0\n",
        "        self.y = df.iloc[:, 0].values\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.y)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        img = self.X[idx].reshape(1, 28, 28)   # grayscale image\n",
        "        label = self.y[idx]\n",
        "        return torch.tensor(img), torch.tensor(label)"
      ],
      "metadata": {
        "id": "g2z5fLB2f6AA"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "train_ds = FashionDataset(train_df)\n",
        "test_ds = FashionDataset(test_df)\n",
        "\n",
        "train_dl = DataLoader(train_ds, batch_size=64, shuffle=True)\n",
        "test_dl = DataLoader(test_ds, batch_size=64)"
      ],
      "metadata": {
        "id": "40_Ti5dGf9Dz"
      },
      "execution_count": 11,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class CNN(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.conv = nn.Sequential(\n",
        "            nn.Conv2d(1,16,3,padding=1),\n",
        "            nn.ReLU(),\n",
        "            nn.MaxPool2d(2),\n",
        "\n",
        "            nn.Conv2d(16,32,3,padding=1),\n",
        "            nn.ReLU(),\n",
        "            nn.MaxPool2d(2)\n",
        "        )\n",
        "\n",
        "        self.fc = nn.Sequential(\n",
        "            nn.Flatten(),\n",
        "            nn.Linear(32*7*7,128),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(128,10)\n",
        "        )\n",
        "\n",
        "    def forward(self,x):\n",
        "        return self.fc(self.conv(x))"
      ],
      "metadata": {
        "id": "gaEgTPbQf_Pi"
      },
      "execution_count": 12,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def train(model, dl, epochs=5):\n",
        "    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "    model.to(device)\n",
        "\n",
        "    opt = optim.Adam(model.parameters(), lr=1e-3)\n",
        "    loss_fn = nn.CrossEntropyLoss()\n",
        "\n",
        "    for e in range(epochs):\n",
        "        model.train()\n",
        "        total = 0\n",
        "\n",
        "        for x,y in dl:\n",
        "            x,y = x.to(device), y.to(device)\n",
        "\n",
        "            opt.zero_grad()\n",
        "            out = model(x)\n",
        "            loss = loss_fn(out,y)\n",
        "            loss.backward()\n",
        "            opt.step()\n",
        "\n",
        "            total += loss.item()\n",
        "\n",
        "        print(f\"Epoch {e+1}, Loss {total:.3f}\")\n",
        "\n",
        "    return model"
      ],
      "metadata": {
        "id": "qssmtGlJgBWy"
      },
      "execution_count": 13,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def evaluate(model, dl):\n",
        "    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "    model.eval()\n",
        "\n",
        "    correct = 0\n",
        "    total = 0\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for x,y in dl:\n",
        "            x,y = x.to(device), y.to(device)\n",
        "            out = model(x)\n",
        "            preds = torch.argmax(out,1)\n",
        "\n",
        "            correct += (preds == y).sum().item()\n",
        "            total += y.size(0)\n",
        "\n",
        "    print(\"Accuracy:\", correct/total)"
      ],
      "metadata": {
        "id": "qC3yt2vygDqr"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "model = CNN()\n",
        "model = train(model, train_dl)\n",
        "evaluate(model, test_dl)"
