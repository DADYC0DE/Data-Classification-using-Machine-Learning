        "\n",
        "            opt.zero_grad()\n",
        "            out = model(x)\n",
        "            loss = loss_fn(out,y)\n",
        "            loss.backward()\n",
        "            opt.step()\n",
        "\n",
        "            total += loss.item()\n",
        "\n",
        "        print(f\"Epoch {e+1}, Loss {total:.3f}\")\n",
