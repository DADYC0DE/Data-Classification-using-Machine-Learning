      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "train_df = pd.read_csv(\"dataset/fashion-mnist_train.csv\")\n",
        "test_df = pd.read_csv(\"dataset/fashion-mnist_test.csv\")\n",
        "\n",
        "print(train_df.shape)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
